# Discord
DISCORD_TOKEN=your-bot-token-here
# Optional: limit slash command sync to a single guild for faster dev iteration
DEV_GUILD_ID=

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=anon_confessions

# Behaviour
CONFESSION_COOLDOWN_SECONDS=600       # 10 minutes
REQUIRE_APPROVAL=false                # if true, confessions go to a mod queue first
LOG_LEVEL=INFO
